<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <link href="https://fonts.googleapis.com/css2?family=Indie+Flower&family=Baloo+Bhaijaan+2:wght@500;700&display=swap" rel="stylesheet">
    <style>
        :root { --line-color: rgba(178, 212, 245, 0.5); --line-thickness: 20px; }
        body { 
            margin: 0; height: 100vh; display: flex; justify-content: center; align-items: center; 
            background-color: #fdf6e9; overflow: hidden; position: relative; cursor: pointer;
            /* لضمان السنتر في الآيفون */
            -webkit-box-pack: center; -webkit-justify-content: center; -ms-flex-pack: center;
        }
        .grid-lines { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; pointer-events: none; }
        .line { position: absolute; background-color: var(--line-color); }
        .v-line { width: var(--line-thickness); height: 0; top: 0; animation: drawV 0.5s ease-out forwards; }
        .h-line { height: var(--line-thickness); width: 0; left: 0; animation: drawH 0.5s ease-out forwards; }
        @keyframes drawV { to { height: 100%; } }
        @keyframes drawH { to { width: 100%; } }
        
        /* تحسين التموضع ليعمل على كل الشاشات */
        .wrapper { 
            position: relative; width: 300px; height: 200px; 
            left: -150%; transform: translateX(0);
            animation: slideInEnvelope 1.2s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards 3.5s; 
        }
        @keyframes slideInEnvelope { to { left: 0; } }
        
        .top-text-container { position: absolute; top: -100px; width: 100%; text-align: center; display: flex; flex-direction: column; align-items: center; z-index: 5; }
        .top-text { font-family: 'Indie Flower', cursive; font-size: 40px; color: #78a9eb; white-space: nowrap; overflow: hidden; width: 0; animation: typing 1.5s steps(12, end) forwards 5s; }
        .curved-underline { width: 200px; height: 30px; background-image: url("data:image/svg+xml,%3Csvg width='200' height='30' viewBox='0 0 200 30' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M10 15 Q 30 5 50 15 T 90 15 T 130 15 T 170 15 T 190 15' stroke='%2378a9eb' stroke-width='2' fill='transparent'/%3E%3C/svg%3E"); background-repeat: no-repeat; background-position: center; margin-top: -10px; opacity: 0; animation: fadeIn 1s ease forwards 6s; }
        .envelope-container { position: relative; width: 100%; height: 100%; background: #fff; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
        .letter { position: absolute; top: 5px; left: 10px; width: 280px; height: 180px; background: white; padding: 15px; box-sizing: border-box; z-index: 2; transition: transform 0.8s ease; font-family: 'Baloo Bhaijaan 2', cursive; font-weight: 500; font-size: 13.5px; line-height: 1.35; text-align: right; direction: rtl; overflow: hidden; }
        .letter strong { font-weight: 700; color: #78a9eb; }
        .front-cover { position: absolute; bottom: 0; width: 0; height: 0; border-left: 150px solid #f9fbff; border-right: 150px solid #f9fbff; border-top: 100px solid transparent; border-bottom: 100px solid #f1f7ff; z-index: 10; }
        .flap { position: absolute; top: 0; width: 0; height: 0; border-left: 150px solid transparent; border-right: 150px solid transparent; border-top: 110px solid #ffffff; transform-origin: top; transition: transform 0.5s ease; z-index: 15; }
        
        .heart { 
            position: absolute; bottom: 85px; left: 50%; transform: translateX(-50%); 
            width: 30px; height: 30px; background: #78a9eb; 
            -webkit-clip-path: path('M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z');
            clip-path: path('M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z'); 
            z-index: 20; transition: 0.3s; 
        }
        
        .wrapper.open .flap { transform: rotateX(180deg); z-index: 1; }
        .wrapper.open .letter { transform: translateY(-145px); z-index: 5; }
        .wrapper.open .heart { opacity: 0; }
        @keyframes typing { from { width: 0; } to { width: 100%; } }
        @keyframes fadeIn { to { opacity: 1; } }
    </style>
</head>
<body onclick="playMusic()">

    <audio id="bgMusic" loop playsinline>
        <source src="https://mp3tourl.com/audio/1774434687263-cea2fdf4-a738-411f-8600-b4b1eb2cd090.mp3" type="audio/mpeg">
    </audio>

    <div class="grid-lines" id="gridLines"></div>

    <div class="wrapper" onclick="toggleEnvelope(event, this)">
        <div class="top-text-container">
            <div class="top-text">I love you!</div>
            <div class="curved-underline"></div>
        </div>
        <div class="flap"></div>
        <div class="heart"></div>
        <div class="envelope-container">
            <div class="letter">
                <strong>إلى أمل</strong><br>
                وجودك في حياتي له أثر هادئ وعميق ما يُمكن تجاهله، وكأنك الشي الجميل اللي يجي بدون موعد ويغيّر كل شي للأفضل.<br>
                أقدّر حضورك كثير، وأحب فيك هدوءك وتفاصيلك البسيطة اللي تترك أثر كبير فيني بدون ما تحسين.<br>
                أعتبرك من الأشخاص القلائل اللي لهم مكانة خاصة عندي، ويمكن أكثر مما أقدر أوصفه بكلام.<br>
                دمتِ قريبة، لأنك ببساطة تعنين لي الكثير
            </div>
            <div class="front-cover"></div>
        </div>
    </div>

    <script>
        const music = document.getElementById('bgMusic');
        let isPlaying = false;

        function playMusic() {
            if (!isPlaying) {
                music.play().then(() => { 
                    isPlaying = true; 
                }).catch(e => {
                    // في الآيفون الصوت يشتغل فقط عند أول تفاعل حقيقي
                    console.log("Audio waiting for interaction");
                });
            }
        }

        function toggleEnvelope(event, element) {
            event.stopPropagation();
            playMusic();
            element.classList.toggle('open');
        }

        const grid = document.getElementById('gridLines');
        const spacing = 80;
        
        // تعديل بسيط لحساب حجم الشاشة بدقة في الجوال
        function drawGrid() {
            grid.innerHTML = '';
            for (let i = 0; i < window.innerWidth; i += spacing) {
                let line = document.createElement('div');
                line.className = 'line v-line';
                line.style.left = i + 'px';
                line.style.animationDelay = (i / 400) + 's';
                grid.appendChild(line);
            }
            setTimeout(() => {
                for (let i = 0; i < window.innerHeight; i += spacing) {
                    let line = document.createElement('div');
                    line.className = 'line h-line';
                    line.style.top = i + 'px';
                    line.style.animationDelay = (i / 400) + 's';
                    grid.appendChild(line);
                }
            }, 1500);
        }

        drawGrid();
        window.addEventListener('resize', drawGrid);
    </script>
</body>
</html>
